    <div class="status-bar">
        <div class="status-message">
            > Ready to explore <span class="status-location" id="locationDisplay">PROFILE CHAMBER</span>
        </div>
        <div id="timeDisplay" style="color: #ffff00;"></div>
    </div>

    <script>
        // Week data for curriculum
        const weeks = [
            { week: 1, reflection: true, make: true },
            { week: 2, reflection: true, make: false },
            { week: 3, reflection: true, make: true },
            { week: 4, reflection: true, make: true },
            { week: 5, reflection: true, make: true },
            { week: 6, reflection: true, make: true },
            { week: 7, reflection: true, make: true },
            { week: 8, reflection: true, make: true },
            { week: 9, reflection: true, make: true },
            { week: 10, reflection: true, make: true },
            { week: 11, reflection: true, make: true },
            { week: 12, reflection: true, make: true },
            { week: 13, reflection: true, make: true }
        ];

        // Progress tracking with localStorage
        const questProgress = {
            data: {},
            
            init() {
                const saved = localStorage.getItem('dh101-quest-progress');
                this.data = saved ? JSON.parse(saved) : {};
            },
            
            save() {
                localStorage.setItem('dh101-quest-progress', JSON.stringify(this.data));
            },
            
            toggle(id) {
                this.data[id] = !this.data[id];
                this.save();
            },
            
            isComplete(id) {
                return this.data[id] || false;
            },
            
            getStats() {
                let reflectionsComplete = 0;
                let makesComplete = 0;
                
                weeks.forEach(w => {
                    if (w.reflection && this.isComplete(`reflection-${w.week}`)) {
                        reflectionsComplete++;
                    }
                    if (w.make && this.isComplete(`make-${w.week}`)) {
                        makesComplete++;
                    }
                });
                
                const totalTasks = 13 + 12; // 13 reflections + 12 makes
                const completedTasks = reflectionsComplete + makesComplete;
                const completionRate = Math.round((completedTasks / totalTasks) * 100);
                const xpGained = completedTasks * 50; // 50 XP per task
                
                return {
                    reflectionsComplete,
                    makesComplete,
                    completionRate,
                    xpGained
                };
            }
        };

        // Room navigation
        function switchRoom(room) {
            // Hide all rooms
            document.querySelectorAll('.content-container').forEach(el => {
                el.classList.remove('active');
            });
            
            // Deactivate all buttons
            document.querySelectorAll('.nav-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            
            // Show selected room
            document.getElementById(room).classList.add('active');
            
            // Activate corresponding button
            event.target.classList.add('active');
            
            // Update status bar
            const locationNames = {
                'profile': 'PROFILE CHAMBER',
                'curriculum': 'CURRICULUM GRIMOIRE',
                'projects': 'CREATIONS VAULT',
                'skills': 'ABILITIES NEXUS'
            };
            
            document.getElementById('locationDisplay').textContent = locationNames[room];
            addStatusMessage(`Entering ${locationNames[room]}...`);
        }

        // Update progress display
        function updateProgressDisplay() {
            const stats = questProgress.getStats();
            document.getElementById('reflectionsCount').textContent = stats.reflectionsComplete;
            document.getElementById('makesCount').textContent = stats.makesComplete;
            document.getElementById('completionRate').textContent = stats.completionRate;
            document.getElementById('experienceGained').textContent = stats.xpGained;
        }

        // Generate weekly milestones checkboxes
        function generateWeeklyMilestones() {
            const container = document.getElementById('weeklyCheckboxes');
            
            weeks.forEach(item => {
                let content = '';
                
                if (item.reflection) {
                    const id = `reflection-${item.week}`;
                    const isComplete = questProgress.isComplete(id);
                    content += `
                        <label class="milestone-item ${isComplete ? 'completed' : ''}" onclick="toggleMilestone('${id}', event)">
                            <input type="checkbox" class="milestone-checkbox" ${isComplete ? 'checked' : ''} onchange="toggleMilestone('${id}', event)">
                            <span class="milestone-label">Week ${item.week} Reflection</span>
                            <span class="milestone-xp">+50 XP</span>
                        </label>
                    `;
                }
                
                if (item.make) {
                    const id = `make-${item.week}`;
                    const isComplete = questProgress.isComplete(id);
                    content += `
                        <label class="milestone-item ${isComplete ? 'completed' : ''}" onclick="toggleMilestone('${id}', event)">
                            <input type="checkbox" class="milestone-checkbox" ${isComplete ? 'checked' : ''} onchange="toggleMilestone('${id}', event)">
                            <span class="milestone-label">Week ${item.week} Make</span>
                            <span class="milestone-xp">+50 XP</span>
                        </label>
                    `;
                }
                
                container.innerHTML += content;
            });
        }

        // Toggle milestone
        function toggleMilestone(id, event) {
            event.preventDefault();
            questProgress.toggle(id);
            updateProgressDisplay();
            
            // Update visual state
            const label = event.currentTarget;
            const checkbox = label.querySelector('.milestone-checkbox');
            checkbox.checked = questProgress.isComplete(id);
            
            if (questProgress.isComplete(id)) {
                label.classList.add('completed');
                addStatusMessage('Quest milestone completed! XP gained!');
            } else {
                label.classList.remove('completed');
                addStatusMessage('Milestone unchecked.');
            }
        }

        // Generate curriculum grid
        function generateCurriculum() {
            const container = document.getElementById('curriculumGrid');
            
            weeks.forEach(item => {
                const card = document.createElement('div');
                card.className = 'curriculum-card';
                
                let content = `
                    <div class="week-badge">WEEK ${item.week}</div>
                    <div style="color: #00ff00;">
                `;
                
                if (item.reflection) {
                    content += `
                        <div style="margin-bottom: 8px;">
                            <span class="reflection-icon">ūüďĚ</span>
                            <a href="reflections/week${String(item.week).padStart(2, '0')}.md" 
                               style="color: #00ff00; text-decoration: none; cursor: pointer;">
                               Reflection Scroll
                            </a>
                        </div>
                    `;
                }
                
                if (item.make) {
                    content += `
                        <div>
                            <span class="make-icon">ūüõ†</span>
                            <a href="makes/week${String(item.week).padStart(2, '0')}.md" 
                               style="color: #00ff00; text-decoration: none; cursor: pointer;">
                               Make & Build
                            </a>
                        </div>
                    `;
                }
                
                content += `</div>`;
                card.innerHTML = content;
                container.appendChild(card);
            });
        }

        // Generate projects grid
        function generateProjects() {
            const container = document.getElementById('projectsGrid');
            
            weeks.forEach(item => {
                if (item.make) {
                    const card = document.createElement('div');
                    card.className = 'project-card';
                    card.innerHTML = `
                        <div class="project-number">ARTIFACT #${item.week}</div>
                        <div class="project-title">Week ${item.week} Creation</div>
                        <div class="project-description">
                            A crafted make exploring digital humanities concepts and critical thinking through practical application.
                        </div>
                        <div style="margin-top: 15px;">
                            <a href="makes/week${String(item.week).padStart(2, '0')}.md" 
                               style="color: #ffff00; text-decoration: underline; cursor: pointer; font-size: 0.9em;">
                               View Details ‚Üí
                            </a>
                        </div>
                    `;
                    container.appendChild(card);
                }
            });
        }

        // Status bar messages
        const messages = [
            'Dungeons explored successfully...',
            'Systems online. Ready for adventure.',
            'Quest objectives tracking...',
            'Knowledge compiled. Wisdom buffering...'
        ];

        let messageIndex = 0;

        function addStatusMessage(msg) {
            messageIndex = (messageIndex + 1) % messages.length;
            setTimeout(() => {
                document.querySelector('.status-message').textContent = 
                    `> ${messages[messageIndex]}`;
            }, 500);
        }

        // Update time display
        function updateTime() {
            const now = new Date();
            const time = now.toLocaleTimeString('en-US', { 
                hour12: false, 
                hour: '2-digit', 
                minute: '2-digit', 
                second: '2-digit' 
            });
            document.getElementById('timeDisplay').textContent = `[${time}]`;
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            questProgress.init();
            generateCurriculum();
            generateProjects();
            generateWeeklyMilestones();
            updateProgressDisplay();
            updateTime();
            setInterval(updateTime, 1000);
        });

        // Keyboard navigation
        document.addEventListener('keydown', (e) => {
            if (e.key === '?' || e.shiftKey && e.key === '/') {
                alert('‚öĒ QUEST CONTROLS ‚öĒ\n\nNavigate between chambers using the menu buttons.\n\nCheck off milestones in the Curriculum Grimoire to track progress.\n\nExperience points (XP) are awarded for each completed milestone.\n\nYour progress is automatically saved!\n\n[Enter any chamber to begin!]');
            }
        });

        // Random status updates
        setInterval(() => {
            const randomMessages = [
                '> Systems humming...',
                '> Standing by for your next quest...',
                '> Dungeons ready to explore...',
                '> Ancient archives accessible...',
                '> Awaiting adventurer input...'
            ];
            
            if (Math.random() > 0.7) {
                document.querySelector('.status-message').textContent = 
                    randomMessages[Math.floor(Math.random() * randomMessages.length)];
            }
        }, 15000);
    </script>
</body>
