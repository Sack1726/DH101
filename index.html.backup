<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DH QUEST - Digital Humanities Portfolio</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Crimson+Text:ital@0;1&display=swap');
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Courier New', monospace;
            background-color: #000000;
            background-image: 
                repeating-linear-gradient(0deg, rgba(50, 50, 50, 0.3) 0px, rgba(50, 50, 50, 0.3) 1px, transparent 1px, transparent 40px),
                repeating-linear-gradient(90deg, rgba(50, 50, 50, 0.3) 0px, rgba(50, 50, 50, 0.3) 1px, transparent 1px, transparent 60px),
                repeating-linear-gradient(45deg, transparent 0px, transparent 2px, rgba(0, 255, 0, 0.01) 2px, rgba(0, 255, 0, 0.01) 4px),
                repeating-linear-gradient(-45deg, transparent 0px, transparent 2px, rgba(0, 255, 0, 0.01) 2px, rgba(0, 255, 0, 0.01) 4px),
                radial-gradient(circle at 20% 30%, rgba(20, 20, 20, 0.8) 0%, transparent 50%),
                radial-gradient(circle at 80% 70%, rgba(20, 20, 20, 0.8) 0%, transparent 50%),
                linear-gradient(180deg, #0d0d0d 0%, #000000 100%);
            color: #00ff00;
            line-height: 1.5;
            overflow-x: hidden;
        }

        /* Dungeon-style scrollbar */
        ::-webkit-scrollbar {
            width: 12px;
        }

        ::-webkit-scrollbar-track {
            background: #1a1a1a;
            border: 1px solid #00ff00;
        }

        ::-webkit-scrollbar-thumb {
            background: #00ff00;
            border: 1px solid #003300;
        }

        .screen {
            min-height: 100vh;
            padding: 20px;
            background: 
                repeating-linear-gradient(
                    0deg,
                    rgba(30, 30, 30, 0.4) 0px,
                    rgba(30, 30, 30, 0.4) 1px,
                    transparent 1px,
                    transparent 35px
                ),
                repeating-linear-gradient(
                    90deg,
                    rgba(30, 30, 30, 0.4) 0px,
                    rgba(30, 30, 30, 0.4) 1px,
                    transparent 1px,
                    transparent 50px
                ),
                repeating-linear-gradient(
                    45deg,
                    transparent,
                    transparent 8px,
                    rgba(0, 255, 0, 0.015) 8px,
                    rgba(0, 255, 0, 0.015) 10px
                ),
                repeating-linear-gradient(
                    -45deg,
                    transparent,
                    transparent 8px,
                    rgba(0, 255, 0, 0.015) 8px,
                    rgba(0, 255, 0, 0.015) 10px
                ),
                repeating-linear-gradient(
                    0deg,
                    rgba(0, 255, 0, 0.03) 0px,
                    rgba(0, 255, 0, 0.03) 1px,
                    transparent 1px,
                    transparent 2px
                ),
                radial-gradient(circle at 25% 25%, rgba(15, 15, 15, 0.6) 0%, transparent 40%),
                radial-gradient(circle at 75% 75%, rgba(15, 15, 15, 0.6) 0%, transparent 40%),
                #000000;
            border: 3px double #00ff00;
            border-style: double;
            margin: 10px;
            box-shadow: 
                0 0 30px rgba(0, 255, 0, 0.4), 
                inset 0 0 30px rgba(0, 255, 0, 0.05),
                inset 0 0 100px rgba(0, 0, 0, 0.8);
            position: relative;
        }

        .screen::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: 
                radial-gradient(circle at 15% 25%, rgba(0, 255, 0, 0.02) 0%, transparent 50%),
                radial-gradient(circle at 85% 75%, rgba(0, 255, 0, 0.02) 0%, transparent 50%),
                radial-gradient(circle at 50% 50%, transparent 30%, rgba(0, 0, 0, 0.3) 100%);
            pointer-events: none;
            z-index: 0;
        }

        .screen > * {
            position: relative;
            z-index: 1;
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 2px dashed #00ff00;
        }

        .title {
            font-size: 2.5em;
            margin-bottom: 10px;
            text-shadow: 
                0 0 10px #00ff00,
                0 0 20px #00ff00,
                2px 2px 0px #003300,
                -1px -1px 0px #006600;
            letter-spacing: 3px;
            font-weight: bold;
        }

        .subtitle {
            font-size: 1.1em;
            color: #00cc00;
            margin-bottom: 10px;
        }

        .ascii-art {
            font-size: 0.7em;
            color: #00ff00;
            white-space: pre;
            overflow-x: auto;
            margin: 10px 0;
            line-height: 1;
            text-shadow: 
                0 0 5px #00ff00,
                0 0 10px #00ff00,
                1px 1px 0px #003300;
            font-weight: bold;
            letter-spacing: -1px;
        }

        .nav-menu {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: center;
            margin: 20px 0;
            padding: 15px;
            border: 2px solid #00ff00;
            background-color: rgba(0, 255, 0, 0.05);
        }

        .nav-btn {
            background-color: #003300;
            color: #00ff00;
            border: 2px solid #00ff00;
            padding: 10px 20px;
            cursor: pointer;
            font-family: 'Courier New', monospace;
            font-size: 1em;
            transition: all 0.3s;
            text-decoration: none;
            display: inline-block;
        }

        .nav-btn:hover {
            background-color: #00ff00;
            color: #0a0a0a;
            box-shadow: 0 0 10px rgba(0, 255, 0, 0.8);
        }

        .nav-btn.active {
            background-color: #00ff00;
            color: #0a0a0a;
            font-weight: bold;
        }

        .content-container {
            display: none;
            animation: fadeIn 0.5s ease-in;
        }

        .content-container.active {
            display: block;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .room {
            border: 2px solid #00ff00;
            padding: 20px;
            margin: 20px 0;
            background-image:
                repeating-linear-gradient(
                    0deg,
                    rgba(0, 255, 0, 0.02),
                    rgba(0, 255, 0, 0.02) 20px,
                    rgba(0, 255, 0, 0.01) 20px,
                    rgba(0, 255, 0, 0.01) 40px
                ),
                repeating-linear-gradient(
                    90deg,
                    rgba(0, 255, 0, 0.01),
                    rgba(0, 255, 0, 0.01) 30px,
                    rgba(0, 255, 0, 0.02) 30px,
                    rgba(0, 255, 0, 0.02) 60px
                );
            background-color: rgba(0, 0, 0, 0.5);
            position: relative;
            box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.5);
        }

        .room::before {
            content: '‚ĒĆ‚ĒÄ CHAMBER ‚ĒÄ‚Ēź';
            position: absolute;
            top: -15px;
            left: 20px;
            background-color: #0a0a0a;
            padding: 0 10px;
            color: #00ff00;
            font-size: 0.9em;
        }

        .room h3 {
            color: #00ff00;
            margin-bottom: 15px;
            font-size: 1.3em;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .treasure {
            border: 1px dashed #00ff00;
            padding: 15px;
            margin: 15px 0;
            background-color: rgba(0, 255, 0, 0.03);
        }

        .treasure-header {
            color: #ffff00;
            font-weight: bold;
            margin-bottom: 8px;
        }

        .stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 10px;
            margin: 20px 0;
        }

        .stat-box {
            border: 1px solid #00ff00;
            padding: 10px;
            background-color: rgba(0, 255, 0, 0.02);
            text-align: center;
        }

        .stat-label {
            color: #00cc00;
            font-size: 0.9em;
        }

        .stat-value {
            color: #00ff00;
            font-size: 1.3em;
            font-weight: bold;
        }

        .quest-log {
            border: 2px solid #00ff00;
            padding: 15px;
            margin: 15px 0;
            background-color: rgba(0, 255, 0, 0.02);
        }

        .quest-item {
            border-left: 3px solid #ffff00;
            padding-left: 15px;
            margin: 10px 0;
            color: #00ff00;
        }

        .quest-status {
            font-size: 0.9em;
            color: #00cc00;
            margin-top: 5px;
        }

        .project-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin: 20px 0;
        }

        .project-card {
            border: 2px solid #00ff00;
            padding: 15px;
            background-color: rgba(0, 255, 0, 0.02);
            transition: all 0.3s;
            cursor: pointer;
        }

        .project-card:hover {
            background-color: rgba(0, 255, 0, 0.1);
            box-shadow: 0 0 15px rgba(0, 255, 0, 0.5);
            transform: translateY(-5px);
        }

        .project-title {
            color: #ffff00;
            font-weight: bold;
            margin-bottom: 8px;
            font-size: 1.1em;
        }

        .project-number {
            color: #00cc00;
            font-size: 0.9em;
            margin-bottom: 8px;
        }

        .project-description {
            color: #00ff00;
            font-size: 0.9em;
            line-height: 1.4;
        }

        .curriculum-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin: 20px 0;
        }

        .curriculum-card {
            border: 2px solid #00ff00;
            padding: 15px;
            background-color: rgba(0, 255, 0, 0.02);
            transition: all 0.3s;
        }

        .curriculum-card:hover {
            background-color: rgba(0, 255, 0, 0.1);
            box-shadow: 0 0 15px rgba(0, 255, 0, 0.5);
        }

        .week-badge {
            display: inline-block;
            background-color: #003300;
            color: #ffff00;
            padding: 5px 10px;
            border: 1px solid #ffff00;
            margin-bottom: 10px;
            font-size: 0.9em;
            font-weight: bold;
        }

        .reflection-icon {
            color: #00cc00;
            margin-right: 5px;
        }

        .make-icon {
            color: #ffff00;
            margin-right: 5px;
        }

        .status-bar {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background-color: #001100;
            border-top: 2px solid #00ff00;
            padding: 10px 20px;
            font-size: 0.9em;
            color: #00ff00;
            z-index: 1000;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .status-message {
            flex: 1;
        }

        .status-location {
            color: #ffff00;
        }

        body {
            padding-bottom: 50px;
        }

        .divider {
            border-top: 1px dashed #00ff00;
            margin: 20px 0;
            padding-top: 20px;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .title {
                font-size: 1.8em;
            }

            .nav-menu {
                flex-direction: column;
            }

            .nav-btn {
                width: 100%;
                text-align: center;
            }

            .project-grid,
            .curriculum-grid {
                grid-template-columns: 1fr;
            }

            .screen {
                margin: 5px;
                padding: 10px;
            }
        }

        .about-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin: 30px 0;
        }

        .about-stat {
            border: 2px solid #00ff00;
            padding: 20px;
            text-align: center;
            background-color: rgba(0, 255, 0, 0.02);
        }

        .about-stat-title {
            color: #ffff00;
            font-size: 1.1em;
            margin-bottom: 10px;
            font-weight: bold;
        }

        .about-stat-value {
            color: #00ff00;
            font-size: 1.5em;
        }

        .links-container {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin: 20px 0;
            justify-content: center;
        }

        .link-btn {
            background-color: #003300;
            color: #00ff00;
            border: 2px solid #00ff00;
            padding: 10px 15px;
            text-decoration: none;
            font-family: 'Courier New', monospace;
            transition: all 0.3s;
            display: inline-block;
            font-size: 0.9em;
        }

        .link-btn:hover {
            background-color: #00ff00;
            color: #0a0a0a;
        }

        .milestone-item {
            display: flex;
            align-items: center;
            padding: 8px;
            border: 1px solid #00ff00;
            background-color: rgba(0, 255, 0, 0.02);
            cursor: pointer;
            transition: all 0.3s;
            user-select: none;
        }

        .milestone-item:hover {
            background-color: rgba(0, 255, 0, 0.08);
        }

        .milestone-item.completed {
            background-color: rgba(0, 255, 0, 0.15);
            border-color: #00cc00;
        }

        .milestone-checkbox {
            width: 20px;
            height: 20px;
            margin-right: 10px;
            cursor: pointer;
            accent-color: #00ff00;
        }

        .milestone-label {
            color: #00ff00;
            cursor: pointer;
            flex: 1;
            font-size: 0.9em;
        }

        .milestone-item.completed .milestone-label {
            color: #00cc00;
            text-decoration: line-through;
        }

        .milestone-xp {
            color: #ffff00;
            font-size: 0.85em;
            font-weight: bold;
            margin-left: 8px;
        }
    </style>
</head>
<body>
    <div class="screen">
        <div class="header">
            <div class="ascii-art">
