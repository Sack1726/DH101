        <!-- CURRICULUM ROOM -->
        <div id="curriculum" class="content-container">
            <div class="room">
                <h3>ūüďĖ CURRICULUM GRIMOIRE</h3>
                <p style="margin-bottom: 20px;">Track all reflections and makes from your semester-long quest through Digital Humanities.</p>

                <div class="quest-log">
                    <h3 style="font-size: 1.1em; margin-bottom: 15px;">‚ö° QUEST PROGRESS</h3>
                    <div class="stats">
                        <div class="stat-box">
                            <div class="stat-label">Reflections Complete</div>
                            <div class="stat-value"><span id="reflectionsCount">0</span>/13</div>
                        </div>
                        <div class="stat-box">
                            <div class="stat-label">Makes Complete</div>
                            <div class="stat-value"><span id="makesCount">0</span>/12</div>
                        </div>
                        <div class="stat-box">
                            <div class="stat-label">Completion Rate</div>
                            <div class="stat-value"><span id="completionRate">0</span>%</div>
                        </div>
                        <div class="stat-box">
                            <div class="stat-label">Experience Gained</div>
                            <div class="stat-value"><span id="experienceGained">0</span> XP</div>
